# Porta do servidor (padrão: 3001)
PORT=3001

# Secret para assinar tokens JWT (OBRIGATÓRIO em produção - use um valor único e seguro)
JWT_SECRET=seu-secret-seguro-aqui

# Caminho do banco SQLite (padrão: server/forum.db)
DB_PATH=server/forum.db

# Chave da YouTube Data API v3 (necessária para importar playlists de capacitação)
YOUTUBE_API_KEY=sua-api-key-aqui
